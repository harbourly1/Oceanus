# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://oceanus:oceanus_dev_2025@localhost:5432/oceanus?schema=public"

# ─── Redis ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET="oceanus-jwt-secret-change-in-production"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── NextAuth ──────────────────────────────────────────
NEXTAUTH_SECRET="oceanus-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── API ───────────────────────────────────────────────
API_URL="http://localhost:3001/api"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# ─── MinIO (S3-compatible) ─────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="oceanus_minio"
S3_SECRET_KEY="oceanus_minio_2025"
S3_BUCKET="oceanus-documents"
S3_REGION="us-east-1"

# ─── App ───────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
